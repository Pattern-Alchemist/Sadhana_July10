# AstroKalki — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.

# PostgreSQL connection string. Required.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/astrokalki

# Public site URL used for sitemap.xml / robots.txt / canonical links + OG tags.
# Required in production so search engines index the correct domain.
NEXT_PUBLIC_SITE_URL=https://astrokalki.example.com

# Optional: disable Next.js telemetry in production
# NEXT_TELEMETRY_DISABLED=1

# Optional: override the default port (3000)
# PORT=3000
