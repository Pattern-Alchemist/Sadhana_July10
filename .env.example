# AstroKalki — Environment Variables
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.

# PostgreSQL connection string. Required.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/astrokalki

# Public site URL used for sitemap.xml / robots.txt / canonical links + OG tags.
# Required in production so search engines index the correct domain.
NEXT_PUBLIC_SITE_URL=https://astrokalki.example.com

# Optional: enables /api/archivist/semantic to generate query embeddings server-side.
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: RFC-001 Phase C — citation-constrained RAG synthesis at
# /api/archivist/synthesize. Ships DARK (default off); enable only after the
# Phase C eval set confirms the refusal floor. See docs/RFC_RAG_ARCHIVIST.md.
# ARCHIVIST_SYNTHESIS_ENABLED=true
# OPENAI_SYNTH_MODEL=gpt-4o-mini
# ARCHIVIST_SYNTH_MONTHLY_BUDGET_USD=5   # hard monthly ceiling, enforced server-side (2× ledger multiplier)
# NEXT_PUBLIC_ARCHIVIST_SYNTHESIS=true   # reveals the "Ask the Custodian" UI toggle

# Optional: disable Next.js telemetry in production
# NEXT_TELEMETRY_DISABLED=1

# Optional: override the default port (3000)
# PORT=3000
